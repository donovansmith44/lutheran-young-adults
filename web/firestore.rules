rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TEMPORARY permissive rules so the emulator can boot for the data-layer tests
    // (Tasks 9–12 use withSecurityRulesDisabled). Task 13 replaces this with the
    // real trust-model rules via TDD.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
